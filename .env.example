PORT=3000
HOST=0.0.0.0
APP_VERSION=0.1.14

# Optional JSONL export for each successful analysis.
ANALYSIS_EXPORT_ENABLED=false
ANALYSIS_EXPORT_PROVIDER=
ANALYSIS_EXPORT_PREFIX=analysis

# Azure Blob export. Use a container-level SAS URL.
# ANALYSIS_EXPORT_PROVIDER=azure
# AZURE_BLOB_SAS_URL=https://account.blob.core.windows.net/container?sv=...

# AWS S3 export.
# ANALYSIS_EXPORT_PROVIDER=s3
# AWS_S3_BUCKET=my-bucket
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_S3_ENDPOINT=
